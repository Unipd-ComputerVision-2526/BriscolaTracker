-double getIoU(Rect r1, Rect r2) {
-    int interArea = (r1 & r2).area();
-    int unionArea = r1.area() + r2.area() - interArea;
-    if (unionArea == 0) return 0;
-    return (double)interArea / unionArea;
-}
